#!/usr/bin/env node
// Post a single message to Slack via the Web API.
// Reads the bot token from the file at SLACK_TOKEN_FILE.

import { readFile } from 'node:fs/promises';
import { createRequire } from 'node:module';

const require = createRequire(import.meta.url);
const { WebClient } = require('@slack/web-api');

const USAGE = `Usage: slack-post post --channel <id-or-name> (--text <text> | --stdin) [--thread <ts>]

Commands:
  post                Post a message to Slack.

Options:
  --channel <value>   Channel ID (C...), channel name (#name), or user ID (U...) for DM.
  --text <value>      Message body. Mutually exclusive with --stdin.
  --stdin             Read message body from standard input.
  --thread <ts>       Post as a reply to the given parent message timestamp.

Environment:
  SLACK_TOKEN_FILE    Path to a file containing the bot token (xoxb-...).
`;

function parseArgs(argv) {
  const args = { _: [] };
  for (let i = 0; i < argv.length; i += 1) {
    const token = argv[i];
    if (token === '--stdin') {
      args.stdin = true;
    } else if (token.startsWith('--')) {
      const key = token.slice(2);
      const value = argv[i + 1];
      if (value === undefined || value.startsWith('--')) {
        throw new Error(`Missing value for --${key}`);
      }
      args[key] = value;
      i += 1;
    } else {
      args._.push(token);
    }
  }
  return args;
}

async function readAllStdin() {
  const chunks = [];
  for await (const chunk of process.stdin) {
    chunks.push(chunk);
  }
  return Buffer.concat(chunks).toString('utf8');
}

async function readToken(path) {
  if (!path) {
    throw new Error('SLACK_TOKEN_FILE env var is not set.');
  }
  const raw = await readFile(path, 'utf8');
  const trimmed = raw.trim();
  if (!trimmed) {
    throw new Error(`Token file is empty: ${path}`);
  }
  return trimmed;
}

async function resolveText(args) {
  if (args.stdin && args.text !== undefined) {
    throw new Error('Pass either --text or --stdin, not both.');
  }
  if (args.stdin) {
    const fromStdin = await readAllStdin();
    if (!fromStdin.trim()) {
      throw new Error('Received empty message body on stdin.');
    }
    return fromStdin;
  }
  if (args.text === undefined) {
    throw new Error('Either --text or --stdin is required.');
  }
  return args.text;
}

async function runPost(argv) {
  const args = parseArgs(argv);
  if (!args.channel) {
    throw new Error('--channel is required.');
  }
  const text = await resolveText(args);
  const token = await readToken(process.env.SLACK_TOKEN_FILE);
  const client = new WebClient(token);
  const response = await client.chat.postMessage({
    channel: args.channel,
    text,
    thread_ts: args.thread,
  });
  if (!response.ok) {
    throw new Error(`Slack API error: ${response.error || 'unknown'}`);
  }
  process.stdout.write(
    JSON.stringify({ ok: true, channel: response.channel, ts: response.ts }) + '\n',
  );
}

async function main() {
  const [command, ...rest] = process.argv.slice(2);
  if (!command) {
    process.stderr.write(USAGE);
    process.exit(2);
  }
  if (command === 'post') {
    await runPost(rest);
    return;
  }
  if (command === '--help' || command === '-h' || command === 'help') {
    process.stdout.write(USAGE);
    return;
  }
  process.stderr.write(`Unknown command: ${command}\n\n${USAGE}`);
  process.exit(2);
}

main().catch((err) => {
  process.stderr.write(`slack-post: ${err.message || err}\n`);
  process.exit(1);
});
